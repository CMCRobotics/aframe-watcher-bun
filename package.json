{
  "name": "@cmcrobotics/aframe-watcher-bun",
  "version": "1.0.0",
  "description": "A modern, high-performance companion watch server for the A-Frame Inspector, built with Bun.",
  "main": "src/index.ts",
  "type": "module",
  "bin": {
    "aframe-watcher-bun": "src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "vendor:inspector": "mkdir -p vendor && cp ../aframe-inspector/dist/aframe-inspector.min.js vendor/",
    "build:inspector": "cd ../aframe-inspector && bun install && bun run dist && cd - && bun run vendor:inspector",
    "build:binary": "bun build src/cli.ts --compile --outfile aframe-watcher",
    "build:example": "bun build examples/server.ts --compile --outfile example-server"
  },
  "keywords": [
    "aframe",
    "webvr",
    "webxr",
    "bun",
    "inspector",
    "watcher"
  ],
  "author": "CERN Micro Club",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmcrobotics/aframe-watcher-bun.git"
  },
  "bugs": {
    "url": "https://github.com/cmcrobotics/aframe-watcher-bun/issues"
  },
  "homepage": "https://github.com/cmcrobotics/aframe-watcher-bun#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "vendor",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@types/bun": "^1.3.11"
  }
}
