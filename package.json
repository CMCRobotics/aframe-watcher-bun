{
  "name": "aframe-watcher-bun",
  "version": "1.0.0",
  "description": "A modern, high-performance companion watch server for the A-Frame Inspector, built with Bun.",
  "main": "src/index.ts",
  "type": "module",
  "bin": {
    "aframe-watcher-bun": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "build:binary": "bun build src/index.ts --compile --outfile aframe-watcher"
  },
  "keywords": [
    "aframe",
    "webvr",
    "webxr",
    "bun",
    "inspector",
    "watcher"
  ],
  "author": "Modern A-Frame Contributors",
  "license": "MIT",
  "dependencies": {
    "@types/bun": "^1.3.11"
  }
}
